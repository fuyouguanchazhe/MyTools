{
  "name": "MyTools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "init": "chmod +x scripts/init-scaffold.sh && ./scripts/init-scaffold.sh",
    "build:local": "chmod +x scripts/build-local.sh && ./scripts/build-local.sh",
    "build:all": "chmod +x scripts/build-all.sh && ./scripts/build-all.sh",
    "clean": "chmod +x scripts/clean.sh && ./scripts/clean.sh",
    "dev:tauri": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "build:tauri": "npm run tauri build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.3.3",
    "@tauri-apps/plugin-fs": "^2.4.2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.3.0",
    "antd": "^5.20.6",
    "dayjs": "^1.11.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.8",
    "vitest": "^4.0.18"
  }
}
